# Public browser configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# The server functions need the same Supabase project values without VITE_ prefixes.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# AI Companion and AI Risk wording
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional override. The application has a default model.
GEMINI_MODEL=gemini-2.5-flash

# SOS email delivery. Configure RESEND_API_KEY, or use Lovable's connector gateway.
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Optional when deployed through Lovable Cloud
LOVABLE_API_KEY=YOUR_LOVABLE_API_KEY

# Web Push notifications
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:you@example.com
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# Supabase care-push Edge Function. Use the same random value in the Edge
# Function secret and in private.runtime_settings.care_push_cron_secret.
CARE_PUSH_CRON_SECRET=GENERATE_A_LONG_RANDOM_SECRET

